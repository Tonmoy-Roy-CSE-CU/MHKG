    rdfs:seeAlso <http://linkedlifedata.com/resource/umls/id/C0038661> ;
    rdfs:seeAlso <https://icd.who.int/browse/2024-01/mms/en#1082933722> .

# ── OWL class equivalences (Level ↔ Schema.org / DBpedia) ────────────────────

mhp:Country     owl:equivalentClass schema:Country .
mhp:University  owl:equivalentClass schema:CollegeOrUniversity .
mhp:Occupation  owl:equivalentClass schema:Occupation .
mhp:Continent   owl:equivalentClass dbpedia:Continent .

# ── Attribute equivalences ────────────────────────────────────────────────────

mha:countryName    owl:equivalentProperty schema:name .
mha:universityName owl:equivalentProperty schema:name .
mha:occupationName owl:equivalentProperty schema:name .
mha:continentName  owl:equivalentProperty schema:name .

# ── GeoNames concept link ─────────────────────────────────────────────────────

<http://www.geonames.org/ontology#A.PCLI>
    rdfs:label "independent political entity (country)"@en ;
    rdfs:seeAlso onto:Country .

