# Year
onto:Year#2024 a qb4o:LevelMember, onto:Year ;
    qb4o:memberOf mhp:Year ;
    mha:yearId "2024" ;
    mha:yearValue 2024 .

# Quarter
onto:Quarter#2024-Q1 a qb4o:LevelMember, onto:Quarter ;
