# =============================================================================
# SECTION 4 — SUICIDE RATE OBSERVATIONS  (FACT_Suicide_Rate — WHO MH_12)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Suicide Rate Observation 1
# Profile  : Bangladesh, Female, Year 2019
# Rate     : 5.2 per 100,000 [CI: 4.1 – 6.5]
# WHO Region: SEARO (South-East Asia)
# ─────────────────────────────────────────────────────────────────────────────

mhsui:SuicideRate501_C2A4E6F0 a qb:Observation ;
    qb:dataSet dataset:mhSuicideDataset ;

    # ── Dimension links ───────────────────────────────────────────────────────
    mhp:suicideGeoDim    onto:Country#Bangladesh ;
    mhp:suicideGenderDim onto:Gender#Female ;
    mhp:suicideTimeDim   onto:Year#2024 ;

    # ── Cuboid shorthand level pointers ──────────────────────────────────────
    mhp:Country onto:Country#Bangladesh ;
    mhp:Gender  onto:Gender#Female ;
    mhp:Year    onto:Year#2024 ;

    # ── Inline WHO metadata ───────────────────────────────────────────────────
    mhp:whoRegionCode  "SEARO" ;
    mhp:whoRegionName  "South-East Asia" ;
    mhp:locationCode   "BGD" ;
    mhp:sexCode        "FMLE" ;
    mhp:valueLabel     "5.2 [4.1-6.5]" ;

    # ── Measures ─────────────────────────────────────────────────────────────
    mhp:suicideRate     "5.2"^^xsd:float ;
    mhp:suicideRateLow  "4.1"^^xsd:float ;
    mhp:suicideRateHigh "6.5"^^xsd:float ;

    # ── Provenance ───────────────────────────────────────────────────────────
    dct:source dataset:mhSuicideDataset ;
    prov:wasAttributedTo <https://www.who.int/data/gho/data/indicators/indicator-details/GHO/age-standardized-suicide-rates-(per-100-000-population)> .


