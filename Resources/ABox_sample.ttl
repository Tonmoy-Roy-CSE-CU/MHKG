# =============================================================================
# SECTION 1 — DIMENSION LEVEL MEMBERS
# =============================================================================

# ── Virtual All root ──────────────────────────────────────────────────────────

onto:All#ALL a qb4o:LevelMember ;
    qb4o:memberOf mhp:All ;
    mha:allId "ALL" ;
    mha:allName "All" .


# ── Geography: Continents ─────────────────────────────────────────────────────

onto:Continent#Asia a qb4o:LevelMember, onto:Continent ;
    qb4o:memberOf mhp:Continent ;
    mha:continentId "1" ;
    mha:continentName "Asia" ;
    mha:inAll onto:All#ALL ;
    owl:sameAs wikidata:Q48 ;
    owl:sameAs geonames:6255147/ .

onto:Continent#NorthAmerica a qb4o:LevelMember, onto:Continent ;
    qb4o:memberOf mhp:Continent ;
    mha:continentId "2" ;
    mha:continentName "North America" ;
    mha:inAll onto:All#ALL ;
    owl:sameAs wikidata:Q49 ;
    owl:sameAs geonames:6255149/ .


# ── Geography: Regions ────────────────────────────────────────────────────────

onto:Region#SouthernAsia a qb4o:LevelMember, onto:Region ;
