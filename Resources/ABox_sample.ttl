    qb4o:memberOf mhp:Month ;
    mha:monthId "2024-03" ;
    mha:monthValue 3 ;
    mha:inQuarter onto:Quarter#2024-Q1 .

# Week
onto:Week#2024-W12 a qb4o:LevelMember, onto:Week ;
    qb4o:memberOf mhp:Week ;
    mha:weekId "2024-W12" ;
    mha:weekValue 12 ;
    mha:inMonth onto:Month#2024-03 .

# Day — timestamp: 2024-03-15
onto:Day#20240315 a qb4o:LevelMember, onto:Day ;
    qb4o:memberOf mhp:Day ;
    mha:dayId "20240315" ;
    mha:dateValue "2024-03-15"^^xsd:date ;
    mha:inWeek onto:Week#2024-W12 .

# Day — timestamp: 2024-03-22
onto:Day#20240322 a qb4o:LevelMember, onto:Day ;
    qb4o:memberOf mhp:Day ;
    mha:dayId "20240322" ;
    mha:dateValue "2024-03-22"^^xsd:date ;
    mha:inWeek onto:Week#2024-W12 .


# =============================================================================
# SECTION 2 — DATASET PROVENANCE
# =============================================================================

dataset:Dataset1 a qb:DataSet ;
    rdfs:label "Student Mental Health Survey (Bangladesh)" ;
    dct:source "Kaggle — Student Mental Health" ;
    dct:identifier <https://www.kaggle.com/datasets/shariful07/student-mental-health> .

dataset:Dataset5 a qb:DataSet ;
    rdfs:label "Workplace Mental Health Survey (USA/Tech)" ;
    dct:source "OSMI Mental Health in Tech Survey" ;
    dct:identifier <https://osmihelp.org/research> .

dataset:mhSurveyDataset a qb:DataSet ;
    rdfs:label "MHKG Survey Cube Dataset — FACT_Mental_Health" ;
    dct:description "Aggregated survey dataset covering student and workplace mental health observations." .

dataset:mhSuicideDataset a qb:DataSet ;
    rdfs:label "MHKG Suicide Rate Dataset — FACT_Suicide_Rate (WHO MH_12)" ;
    dct:description "WHO age-standardised suicide rates per 100,000 population." ;
    dct:identifier <https://www.who.int/data/gho/data/indicators/indicator-details/GHO/age-standardized-suicide-rates-(per-100-000-population)> .


# =============================================================================
# SECTION 3 — SURVEY OBSERVATIONS  (FACT_Mental_Health)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Observation 1
# Profile  : Female, 22, Bangladesh, University of Dhaka, 1st year, CGPA 3.25
#            Student occupation, Good lifestyle, Strong support system
# Measures : Depression=2, Anxiety=2, Stress=2, Sleep=7h, Screen=4h,
#            PhysAct=3h/wk, SocialSupport=8
# Timestamp: 2024-03-15
# ─────────────────────────────────────────────────────────────────────────────

mhobs:Survey1001_A3F9B2C1 a qb:Observation ;
    qb:dataSet dataset:mhSurveyDataset ;

    # ── Dimension links ──────────────────────────────────────────────────────
    mhp:geographyDim     onto:Country#Bangladesh ;
    mhp:demographicsDim  onto:Gender#Female ;
    mhp:academicDim      onto:CGPACategory#30-35 ;
    mhp:workEnvDim       onto:Occupation#1 ;
    mhp:lifestyleDim     onto:Lifestyle#1 ;
    mhp:supportSystemDim onto:SupportSystem#1 ;
    mhp:timeDim          onto:Day#20240315 ;

    # ── Cuboid shorthand level pointers (used by mhSurveyCuboid) ────────────
    mhp:Country      onto:Country#Bangladesh ;
    mhp:Gender       onto:Gender#Female ;
    mhp:AgeGroup     onto:AgeGroup#21-25 ;
    mhp:CGPACategory onto:CGPACategory#30-35 ;
    mhp:AcademicYear onto:AcademicYear#1stYear ;
    mhp:Occupation   onto:Occupation#1 ;
    mhp:SleepQuality onto:Lifestyle#1 ;
    mhp:SupportSystem onto:SupportSystem#1 ;
    mhp:Year         onto:Year#2024 ;
    mhp:Day          onto:Day#20240315 ;

    # ── Inline / degenerate attributes ──────────────────────────────────────
    mhp:age                "22"^^xsd:float ;
    mhp:cgpa               "3.25"^^xsd:float ;
    mhp:relationshipStatus "Single" ;
    mhp:socialSupport      "High" ;
    mhp:familyHistory      "No" ;
    mhp:treatment          "No" ;

    # ── Measures ─────────────────────────────────────────────────────────────
    mhp:depressionScore        "2.0"^^xsd:float ;
    mhp:anxietyScore           "2.0"^^xsd:float ;
    mhp:stressLevel            "2.0"^^xsd:float ;
    mhp:sleepHours             "7.0"^^xsd:float ;
    mhp:screenTime             "4.0"^^xsd:float ;
    mhp:physicalActivityHours  "3.0"^^xsd:float ;
    mhp:socialSupportScore     "8.0"^^xsd:float ;

    # ── Provenance ───────────────────────────────────────────────────────────
    dct:source dataset:Dataset1 ;
    prov:wasAttributedTo <https://www.kaggle.com/datasets/shariful07/student-mental-health> .


