    mha:regionId "3" ;
    mha:regionName "Southern Asia" ;
    mha:inContinent onto:Continent#Asia .

onto:Region#NorthernAmerica a qb4o:LevelMember, onto:Region ;
    qb4o:memberOf mhp:Region ;
    mha:regionId "8" ;
    mha:regionName "Northern America" ;
    mha:inContinent onto:Continent#NorthAmerica .


# ── Geography: Countries ─────────────────────────────────────────────────────

onto:Country#Bangladesh a qb4o:LevelMember, onto:Country ;
    qb4o:memberOf mhp:Country ;
    mha:countryId "12" ;
    mha:countryName "Bangladesh" ;
    mha:inRegion onto:Region#SouthernAsia ;
    owl:sameAs wikidata:Q902 ;
    owl:sameAs geonames:1210997/ ;
    owl:sameAs dbpedia:Bangladesh .

onto:Country#USA a qb4o:LevelMember, onto:Country ;
    qb4o:memberOf mhp:Country ;
    mha:countryId "101" ;
    mha:countryName "USA" ;
    mha:inRegion onto:Region#NorthernAmerica ;
    owl:sameAs wikidata:Q30 ;
    owl:sameAs geonames:6252001/ ;
    owl:sameAs dbpedia:United_States .


# ── Demographics: GenderCategories ───────────────────────────────────────────

onto:GenderCategory#Binary a qb4o:LevelMember, onto:GenderCategory ;
    qb4o:memberOf mhp:GenderCategory ;
    mha:genderCategoryId "Binary" ;
    mha:genderCategory "Binary" ;
    mha:inAll onto:All#ALL .

onto:GenderCategory#NonBinary a qb4o:LevelMember, onto:GenderCategory ;
    qb4o:memberOf mhp:GenderCategory ;
    mha:genderCategoryId "NonBinary" ;
    mha:genderCategory "Non-Binary" ;
    mha:inAll onto:All#ALL .


# ── Demographics: Genders ─────────────────────────────────────────────────────

onto:Gender#Male a qb4o:LevelMember, onto:Gender ;
    qb4o:memberOf mhp:Gender ;
    mha:genderId "1" ;
    mha:gender "Male" ;
    mha:inGenderCategory onto:GenderCategory#Binary .

onto:Gender#Female a qb4o:LevelMember, onto:Gender ;
    qb4o:memberOf mhp:Gender ;
    mha:genderId "2" ;
    mha:gender "Female" ;
    mha:inGenderCategory onto:GenderCategory#Binary .

onto:Gender#NonBinary a qb4o:LevelMember, onto:Gender ;
    qb4o:memberOf mhp:Gender ;
    mha:genderId "3" ;
    mha:gender "Non-binary" ;
    mha:inGenderCategory onto:GenderCategory#NonBinary .


# ── Demographics: LifeStages ──────────────────────────────────────────────────

onto:LifeStage#YoungAdult a qb4o:LevelMember, onto:LifeStage ;
    qb4o:memberOf mhp:LifeStage ;
    mha:lifeStageId "2" ;
    mha:lifeStageName "Young Adult" ;
    mha:inAll onto:All#ALL .

onto:LifeStage#Adult a qb4o:LevelMember, onto:LifeStage ;
    qb4o:memberOf mhp:LifeStage ;
    mha:lifeStageId "3" ;
    mha:lifeStageName "Adult" ;
    mha:inAll onto:All#ALL .


# ── Demographics: AgeGroups ───────────────────────────────────────────────────

onto:AgeGroup#21-25 a qb4o:LevelMember, onto:AgeGroup ;
    qb4o:memberOf mhp:AgeGroup ;
    mha:ageGroupId "3" ;
    mha:ageGroupRange "21-25" ;
    mha:inLifeStage onto:LifeStage#YoungAdult .

onto:AgeGroup#26-30 a qb4o:LevelMember, onto:AgeGroup ;
    qb4o:memberOf mhp:AgeGroup ;
    mha:ageGroupId "4" ;
    mha:ageGroupRange "26-30" ;
    mha:inLifeStage onto:LifeStage#Adult .


# ── Academic: Universities ────────────────────────────────────────────────────

onto:University#UniversityOfDhaka a qb4o:LevelMember, onto:University ;
    qb4o:memberOf mhp:University ;
    mha:universityId "5" ;
    mha:universityName "University of Dhaka" ;
    mha:inCountryAcad onto:Country#Bangladesh .

onto:University#MITMassachusettsInstituteOfTechnology a qb4o:LevelMember, onto:University ;
    qb4o:memberOf mhp:University ;
    mha:universityId "22" ;
    mha:universityName "MIT (Massachusetts Institute of Technology)" ;
    mha:inCountryAcad onto:Country#USA .


# ── Academic: AcademicYears ───────────────────────────────────────────────────

onto:AcademicYear#1stYear a qb4o:LevelMember, onto:AcademicYear ;
    qb4o:memberOf mhp:AcademicYear ;
    mha:academicYearId "1" ;
    mha:academicYearName "1st year" ;
    mha:inUniversity onto:University#UniversityOfDhaka .

onto:AcademicYear#3rdYear a qb4o:LevelMember, onto:AcademicYear ;
    qb4o:memberOf mhp:AcademicYear ;
    mha:academicYearId "3" ;
    mha:academicYearName "3rd year" ;
    mha:inUniversity onto:University#MITMassachusettsInstituteOfTechnology .


# ── Academic: CGPACategories ──────────────────────────────────────────────────

# Band: 3.0–3.5  (midpoint cgpa = 3.25)
onto:CGPACategory#30-35 a qb4o:LevelMember, onto:CGPACategory ;
    qb4o:memberOf mhp:CGPACategory ;
    mha:cgpaCategoryId "2" ;
    mha:cgpaCategory "3.0–3.5" ;
    mha:cgpaRange "3.0–3.5" ;
    mha:cgpaValue "3.25"^^xsd:float ;
    mha:inAcademicYear onto:AcademicYear#1stYear .

# Band: 3.5–4.0  (midpoint cgpa = 3.75)
onto:CGPACategory#35-40 a qb4o:LevelMember, onto:CGPACategory ;
    qb4o:memberOf mhp:CGPACategory ;
    mha:cgpaCategoryId "3" ;
    mha:cgpaCategory "3.5–4" ;
    mha:cgpaRange "3.5–4.0" ;
    mha:cgpaValue "3.75"^^xsd:float ;
    mha:inAcademicYear onto:AcademicYear#3rdYear .


# ── Work Environment: Occupations ────────────────────────────────────────────

# Record 1 — Student with work context
onto:Occupation#1 a qb4o:LevelMember, onto:Occupation ;
    qb4o:memberOf mhp:Occupation ;
    mha:occupationId "1" ;
    mha:occupationName "Student" ;
    mha:workInterest "Yes" ;
    mha:benefits "Yes" ;
    mha:careOptions "Yes" ;
    mha:techCompany "No" .

# Record 2 — Corporate employee
onto:Occupation#2 a qb4o:LevelMember, onto:Occupation ;
    qb4o:memberOf mhp:Occupation ;
    mha:occupationId "2" ;
    mha:occupationName "Corporate" ;
    mha:workInterest "Maybe" ;
    mha:benefits "Yes" ;
    mha:careOptions "Not sure" ;
    mha:techCompany "Yes" .


# ── Lifestyle (mhp:SleepQuality level — holds all lifestyle attributes) ───────

# Lifestyle #1: Good sleep / High activity / Balanced diet
onto:Lifestyle#1 a qb4o:LevelMember, onto:Lifestyle ;
    qb4o:memberOf mhp:SleepQuality ;
    mha:lifestyleId "1" ;
    mha:sleepQuality "Good" ;
    mha:physicalActivity "High" ;
    mha:dietType "Balanced" ;
    mha:substanceUse "Never" ;
    mha:changesHabits "No" ;
    mha:moodSwings "Low" ;
    mha:copingStruggles "No" ;
    mha:daysIndoorsCategory "Go out every day" .

# Lifestyle #2: Poor sleep / Low activity / Junk food
onto:Lifestyle#2 a qb4o:LevelMember, onto:Lifestyle ;
    qb4o:memberOf mhp:SleepQuality ;
    mha:lifestyleId "2" ;
    mha:sleepQuality "Poor" ;
    mha:physicalActivity "Low" ;
    mha:dietType "Junk Food" ;
    mha:substanceUse "Occasional" ;
    mha:changesHabits "Yes" ;
    mha:moodSwings "High" ;
    mha:copingStruggles "Yes" ;
    mha:daysIndoorsCategory "15–30 days" .


# ── Support Systems ───────────────────────────────────────────────────────────

# Support #1: Strong support, no family history, under treatment
onto:SupportSystem#1 a qb4o:LevelMember, onto:SupportSystem ;
    qb4o:memberOf mhp:SupportSystem ;
    mha:supportSystemId "1" ;
    mha:socialSupportAttr "High" ;
    mha:familyHistoryAttr "No" ;
    mha:treatmentAttr "Yes" .

# Support #2: Weak support, family history, no treatment
onto:SupportSystem#2 a qb4o:LevelMember, onto:SupportSystem ;
    qb4o:memberOf mhp:SupportSystem ;
    mha:supportSystemId "2" ;
    mha:socialSupportAttr "Low" ;
    mha:familyHistoryAttr "Yes" ;
    mha:treatmentAttr "No" .


